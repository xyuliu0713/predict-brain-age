import pandas as pd
import numpy as np

from sklearn.model_selection import KFold

from sklearn.preprocessing import StandardScaler

from sklearn.metrics import (
    mean_absolute_error,
    r2_score
)

from xgboost import XGBRegressor

# ============================================
# 1. 读取数据
# ============================================

DATA_PATH = (
    "/Users/molin/Downloads/ML/Train/"
    "brain_age_features.xlsx"
)

df = pd.read_excel(DATA_PATH)

print("Data shape:")
print(df.shape)

# ============================================
# 2. 清洗 column names
# ============================================

df.columns = [

    str(c)
    .strip()
    .replace(" ", "_")
    .replace("-", "_")
    .replace("__", "_")

    for c in df.columns
]

# ============================================
# 3. X / y
# ============================================

X = df.drop(
    columns=["subject_ID", "age"]
)

y = df["age"]

print("\nX shape:")
print(X.shape)

print("\ny shape:")
print(y.shape)

# ============================================
# 4. 10-fold CV
# ============================================

kf = KFold(
    n_splits=10,
    shuffle=True,
    random_state=42
)

# 保存结果
mae_list = []
r2_list = []

all_true = []
all_pred = []

# ============================================
# 5. Cross-validation loop
# ============================================

fold = 1

for train_index, test_index in kf.split(X):

    print("\n===================================")
    print(f"Fold {fold}")

    # ----------------------------------------
    # split
    # ----------------------------------------

    X_train = X.iloc[train_index]
    X_test = X.iloc[test_index]

    y_train = y.iloc[train_index]
    y_test = y.iloc[test_index]

    print("Train size:", X_train.shape)
    print("Test size:", X_test.shape)

    # ----------------------------------------
    # scaler
    # IMPORTANT:
    # fit only on train
    # ----------------------------------------

    scaler = StandardScaler()

    X_train_scaled = scaler.fit_transform(
        X_train
    )

    X_test_scaled = scaler.transform(
        X_test
    )

    # ----------------------------------------
    # model
    # ----------------------------------------

    model = XGBRegressor(

        n_estimators=300,
        max_depth=4,
        learning_rate=0.05,
        subsample=0.8,
        colsample_bytree=0.8,
        random_state=42
    )

    # ----------------------------------------
    # train
    # ----------------------------------------

    model.fit(
        X_train_scaled,
        y_train
    )

    # ----------------------------------------
    # predict
    # ----------------------------------------

    y_pred = model.predict(
        X_test_scaled
    )

    # ----------------------------------------
    # metrics
    # ----------------------------------------

    mae = mean_absolute_error(
        y_test,
        y_pred
    )

    r2 = r2_score(
        y_test,
        y_pred
    )

    print(f"MAE: {mae:.2f}")

    print(f"R²: {r2:.3f}")

    mae_list.append(mae)
    r2_list.append(r2)

    # 保存所有 prediction
    all_true.extend(y_test)
    all_pred.extend(y_pred)

    fold += 1

# ============================================
# 6. Final results
# ============================================

print("\n===================================")
print("FINAL RESULTS")
print("===================================")

print(f"\nMean MAE: {np.mean(mae_list):.2f}")

print(f"STD MAE: {np.std(mae_list):.2f}")

print(f"\nMean R²: {np.mean(r2_list):.3f}")

print(f"STD R²: {np.std(r2_list):.3f}")

# ============================================
# 7. Brain Age Gap
# ============================================

brain_age_gap = np.array(all_pred) - np.array(all_true)

print("\nBrain Age Gap summary:")

print(pd.Series(brain_age_gap).describe())

# ============================================
# 8. 保存 prediction
# ============================================

results_df = pd.DataFrame({

    "True_Age": all_true,

    "Predicted_Age": all_pred,

    "Brain_Age_Gap": brain_age_gap
})

output_path = (
    "/Users/molin/Downloads/ML/Train/"
    "10fold_cv_predictions.csv"
)

results_df.to_csv(
    output_path,
    index=False
)

print("\nSaved predictions:")
print(output_path)

# ============================================
# 9. feature importance
# ============================================

importance = model.feature_importances_

importance_df = pd.DataFrame({

    "Feature": X.columns,

    "Importance": importance
})

importance_df = importance_df.sort_values(
    by="Importance",
    ascending=False
)

importance_output = (
    "/Users/molin/Downloads/ML/Train/"
    "10fold_feature_importance.csv"
)

importance_df.to_csv(
    importance_output,
    index=False
)

print("\nSaved feature importance:")
print(importance_output)

print("\nTop 20 important features:")

print(
    importance_df.head(20)
)

print("\nDone.")
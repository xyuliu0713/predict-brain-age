df = pd.read_excel(file_path)

# 清理列名空格（避免报错）
df.columns = df.columns.str.strip()

# （可选）确保Gender是int
df["Gender (1=Female, 2=Male)"] = df["Gender (1=Female, 2=Male)"].astype(int)

# 定义输出路径
output_dir = "/Users/molin/Downloads/ML2/Test/split_age"

# 分组
female_ge = df[(df["Gender (1=Female, 2=Male)"] == 1) & (df["MRI scanner"] == "GE")]

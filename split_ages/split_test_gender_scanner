male_ge = df[(df["Gender (1=Female, 2=Male)"] == 2) & (df["MRI scanner"] == "GE")]
male_siemens = df[(df["Gender (1=Female, 2=Male)"] == 2) & (df["MRI scanner"] == "SIEMENS")]

# 保存为4个独立Excel文件
female_ge.to_excel(output_dir + "Female_GE_young.xlsx", index=False)
female_siemens.to_excel(output_dir + "Female_SIEMENS_young.xlsx", index=False)
male_ge.to_excel(output_dir + "Male_GE_young.xlsx", index=False)
male_siemens.to_excel(output_dir + "Male_SIEMENS_young.xlsx", index=False)


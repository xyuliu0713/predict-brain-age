import re
import pandas as pd

# Excel 文件路径
file_path = "/Users/molin/Downloads/ML/Train/brain_age_features.xlsx"

# 读取 Excel
df = pd.read_excel(file_path)

# 清理列名：
# 1. 删除 "1600_"
# 2. 删除 "-"
# 3. 将多个连续 "_" 变成一个 "_"
df.columns = [
    re.sub(r"_+", "_", col.replace("1600_", "").replace("-", "_"))
    for col in df.columns
]

# 保存（覆盖原文件）
df.to_excel(file_path, index=False)

print("Excel 列名清理完成")
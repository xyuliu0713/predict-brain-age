    .replace(" ", "_")
    .replace("-", "_")
    .replace("(", "")
    .replace(")", "")
    .replace("=", "_")
    .replace("__", "_")

    for c in test_df.columns
]

# =====================================================
# TEST BRAIN FEATURES
# =====================================================

test_brain_features = test_df[
    brain_feature_cols
]

# =====================================================
# TEST GENDER
# =====================================================

test_gender_binary = (

    test_df[GENDER_COL] == 2

).astype(int)

test_gender_binary = pd.DataFrame({

    "Gender_Male": test_gender_binary
})

# =====================================================
# TEST SCANNER DUMMIES
# =====================================================

test_scanner_dummies = pd.get_dummies(

    test_df[SCANNER_COL],

    prefix="Scanner",

    drop_first=True
)

# =====================================================
# MATCH TRAIN COLUMNS
# =====================================================

test_scanner_dummies = (

    test_scanner_dummies.reindex(

        columns=scanner_dummies.columns,

        fill_value=0
    )
)

# =====================================================
# FINAL TEST X
# =====================================================

X_test_final = pd.concat(

    [

        test_brain_features,

        test_gender_binary,

        test_scanner_dummies

    ],

    axis=1
)

# =====================================================
# MATCH TRAIN FEATURE ORDER
# =====================================================

X_test_final = X_test_final.reindex(

    columns=X.columns
)

print("\nFinal test X shape:")

print(X_test_final.shape)

# =====================================================
# APPLY SCALER + PCA
# =====================================================

X_test_scaled = final_scaler.transform(
    X_test_final
)

X_test_pca = final_pca.transform(
    X_test_scaled
)

# =====================================================
# PREDICT TEST
# =====================================================

test_predictions = final_model.predict(
    X_test_pca
)

# =====================================================
# SAVE TEST PREDICTIONS
# =====================================================

prediction_df = pd.DataFrame({

    "Predicted_Age": np.round(

        test_predictions

    ).astype(int)
})

# add subject_ID if exists

if SUBJECT_COL in test_df.columns:

    prediction_df.insert(

        0,

        SUBJECT_COL,

        test_df[SUBJECT_COL]
    )

test_output_path = (

    OUTPUT_DIR_TEST +

    "brain_age_test_predictions_covariates.csv"
)

prediction_df.to_csv(

    test_output_path,

    index=False
)

print("\n===================================")
print("TEST PREDICTIONS SAVED")
print("===================================")

print(test_output_path)

print("\n===================================")
print("ALL ANALYSES FINISHED")
